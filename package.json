{
  "name": "keking",
  "version": "1.0.0",
  "description": "Discord bot boilerplate with discord.js and TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check": "pnpm build",
    "start": "node --enable-source-maps dist/index.js",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "docker:build": "docker build -t keking-bot .",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f bot"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0"
  }
}
